{
  "name": "kigumi",
  "displayName": "Kigumi",
  "description": "Kiguim is a viewer tool for Kumiki designs",
  "version": "0.1.3",
  "publisher": "minimaple",
  "repository": {
    "type": "git",
    "url": "https://github.com/minimapletinytools/kumiki/kigumi"
  },
  "engines": {
    "vscode": "^1.63.0"
  },
  "keywords": [
    "cad",
    "timber",
    "woodworking",
    "geometry",
    "viewer"
  ],
  "categories": [
    "Visualization"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:kigumi.openCurrentFileInViewer",
    "onCommand:kigumi.automationOpenFileInViewer",
    "onCommand:kigumi.initializeProjectInWorkspace",
    "onView:kigumi.explorer"
  ],
  "main": "./extension.js",
  "icon": "templogo.png",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kigumi",
          "title": "Kigumi",
          "icon": "templogo.png"
        }
      ]
    },
    "views": {
      "kigumi": [
        {
          "id": "kigumi.explorer",
          "name": "Kigumi Explorer",
          "icon": "templogo.png"
        }
      ]
    },
    "commands": [
      {
        "command": "kigumi.openCurrentFileInViewer",
        "title": "Kigumi: Open Current File In Viewer",
        "icon": "$(play)"
      },
      {
        "command": "kigumi.initializeProjectInWorkspace",
        "title": "Kigumi: Initialize Project",
        "icon": "$(rocket)"
      },
      {
        "command": "kigumi.refreshSidebar",
        "title": "Kigumi: Refresh Sidebar",
        "icon": "$(refresh)"
      },
      {
        "command": "kigumi.toggleGroupByPatternbook",
        "title": "Kigumi: Toggle Patternbook Grouping",
        "icon": "$(list-tree)"
      },
      {
        "command": "kigumi.updateKumiki",
        "title": "Kigumi: Update Kumiki",
        "icon": "$(cloud-download)"
      },
      {
        "command": "kigumi.openWebsite",
        "title": "Kigumi: Open Kumiki Website",
        "icon": "$(link-external)"
      },
      {
        "command": "kigumi.toggleAutoRefreshOnFileChange",
        "title": "Kigumi: Toggle Auto Refresh On File Change",
        "icon": "$(sync)"
      },
      {
        "command": "kigumi.automationListSessions",
        "title": "Kigumi: Automation List Sessions"
      },
      {
        "command": "kigumi.automationOpenFileInViewer",
        "title": "Kigumi: Automation Open File In Viewer"
      },
      {
        "command": "kigumi.automationRefreshSession",
        "title": "Kigumi: Automation Refresh Session"
      },
      {
        "command": "kigumi.automationReadSessionLogs",
        "title": "Kigumi: Automation Read Session Logs"
      },
      {
        "command": "kigumi.automationGetCameraState",
        "title": "Kigumi: Automation Get Camera State"
      },
      {
        "command": "kigumi.automationSetCameraState",
        "title": "Kigumi: Automation Set Camera State"
      },
      {
        "command": "kigumi.captureScreenshotBundle",
        "title": "Kigumi: Capture Screenshot Bundle"
      },
      {
        "command": "kigumi.explorer",
        "title": "Kigumi: Open Explorer",
        "icon": "$(file-directory)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "kigumi.toggleGroupByPatternbook",
          "when": "view == kigumi.explorer",
          "group": "navigation@2"
        },
        {
          "command": "kigumi.refreshSidebar",
          "when": "view == kigumi.explorer",
          "group": "navigation@3"
        }
      ],
      "commandPalette": [
        {
          "command": "kigumi.refreshSidebar",
          "when": "false"
        },
        {
          "command": "kigumi.toggleGroupByPatternbook",
          "when": "false"
        },
        {
          "command": "kigumi.updateKumiki",
          "when": "false"
        },
        {
          "command": "kigumi.openWebsite",
          "when": "false"
        },
        {
          "command": "kigumi.toggleAutoRefreshOnFileChange",
          "when": "false"
        },
        {
          "command": "kigumi.captureScreenshotBundle",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Kigumi",
      "properties": {
        "kigumi.viewer.autoRefreshOnFileChange": {
          "type": "boolean",
          "default": false,
          "description": "Automatically refresh open Kigumi viewers when watched files change."
        },
        "kigumi.viewer.logRetentionDays": {
          "type": "number",
          "default": 15,
          "minimum": 0,
          "description": "Delete Kigumi log files in .kigumi/logs that are older than this many days when the extension starts or the setting changes."
        }
      }
    }
  },
  "scripts": {
    "prepare:instructions": "node ./scripts/prepare-bundled-instructions.js",
    "update-vendor": "node ./scripts/update-vendor.js",
    "vscode:prepublish": "npm run prepare:instructions",
    "test": "npm run test:unit",
    "test:unit": "jest",
    "test:runner": "jest --runInBand __tests__/runner-protocol.test.js",
    "test:ext": "node ./test/run-extension-tests.js",
    "test:ext:initial": "node ./test/run-extension-tests.js --suite initial",
    "test:ext:complex": "node ./test/run-extension-tests.js --suite complex",
    "test:ext:complex:grep": "node ./test/run-extension-tests.js --suite complex --grep",
    "test:all": "npm run test:unit && npm run test:ext"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2",
    "@vscode/test-electron": "^2.5.2",
    "@types/vscode": "^1.63.0",
    "jest": "^29.7.0",
    "mocha": "^11.2.2"
  }
}
