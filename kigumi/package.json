{
  "name": "kigumi",
  "displayName": "Kigumi",
  "description": "Kiguim is a viewer tool for Kumiki designs",
  "version": "0.1.2",
  "publisher": "minimaple",
  "repository": {
    "type": "git",
    "url": "https://github.com/minimapletinytools/kumiki/kigumi"
  },
  "engines": {
    "vscode": "^1.63.0"
  },
  "keywords": [
    "cad",
    "timber",
    "woodworking",
    "geometry",
    "viewer"
  ],
  "categories": [
    "Visualization"
  ],
  "activationEvents": [
    "onCommand:kigumi.openCurrentFileInViewer",
    "onCommand:kigumi.initializeProjectInWorkspace",
    "onView:kigumi.explorer"
  ],
  "main": "./extension.js",
  "icon": "templogo.png",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kigumi",
          "title": "Kigumi",
          "icon": "templogo.png"
        }
      ]
    },
    "views": {
      "kigumi": [
        {
          "id": "kigumi.explorer",
          "name": "Kigumi Explorer",
          "icon": "templogo.png"
        }
      ]
    },
    "commands": [
      {
        "command": "kigumi.openCurrentFileInViewer",
        "title": "Kigumi: Open Current File In Viewer",
        "icon": "$(play)"
      },
      {
        "command": "kigumi.projectHeaderAction",
        "title": "Kigumi: Initialize Project",
        "icon": "$(rocket)"
      },
      {
        "command": "kigumi.initializeProjectInWorkspace",
        "title": "Kigumi: Initialize Project",
        "icon": "$(rocket)"
      },
      {
        "command": "kigumi.refreshSidebar",
        "title": "Kigumi: Refresh Sidebar",
        "icon": "$(refresh)"
      },
      {
        "command": "kigumi.refreshPatterns",
        "title": "Kigumi: Refresh Patterns",
        "icon": "$(refresh)"
      },
      {
        "command": "kigumi.toggleGroupByPatternbook",
        "title": "Kigumi: Toggle Patternbook Grouping",
        "icon": "$(list-tree)"
      },
      {
        "command": "kigumi.updateKumiki",
        "title": "Kigumi: Update Kumiki",
        "icon": "$(cloud-download)"
      },
      {
        "command": "kigumi.openWebsite",
        "title": "Kigumi: Open Kumiki Website",
        "icon": "$(link-external)"
      },
      {
        "command": "kigumi.explorer",
        "title": "Kigumi: Open Explorer",
        "icon": "$(file-directory)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "kigumi.toggleGroupByPatternbook",
          "when": "view == kigumi.explorer",
          "group": "navigation@2"
        },
        {
          "command": "kigumi.refreshSidebar",
          "when": "view == kigumi.explorer",
          "group": "navigation@4"
        }
      ],
      "commandPalette": [
        {
          "command": "kigumi.projectHeaderAction",
          "when": "false"
        },
        {
          "command": "kigumi.refreshSidebar",
          "when": "false"
        },
        {
          "command": "kigumi.refreshPatterns",
          "when": "false"
        },
        {
          "command": "kigumi.toggleGroupByPatternbook",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "prepare:instructions": "node ./scripts/prepare-bundled-instructions.js",
    "update-vendor": "node ./scripts/update-vendor.js",
    "vscode:prepublish": "npm run prepare:instructions",
    "test": "npm run test:unit",
    "test:unit": "jest",
    "test:runner": "jest --runInBand __tests__/runner-protocol.test.js",
    "test:ext": "node ./test/run-extension-tests.js",
    "test:all": "npm run test:unit && npm run test:ext"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2",
    "@vscode/test-electron": "^2.5.2",
    "@types/vscode": "^1.63.0",
    "jest": "^29.7.0",
    "mocha": "^11.2.2"
  }
}
