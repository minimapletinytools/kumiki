---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const gallery = [
  { src: `${base}/photos/oscarshed.png`, alt: "Oscar's Shed timber frame" },
  { src: `${base}/photos/sawhorsey.png`, alt: 'Sawhorse pattern' },
  { src: `${base}/photos/round_crosslap_joint.png`, alt: 'Round crosslap joint detail' },
  { src: `${base}/photos/wedged_half_dovetail.png`, alt: 'Wedged half dovetail joint' },
  { src: `${base}/photos/tinyhouse120_front.png`, alt: 'Tiny house, front view' },
  { src: `${base}/photos/extension-screenshot.png`, alt: 'Kigumi VS Code extension' },
  { src: `${base}/photos/joint_intersection_detail.png`, alt: 'Four-way beam intersection with tenon detail' },
  { src: `${base}/photos/corner_joint_patterns.png`, alt: 'Gallery of corner joint patterns' },
  { src: `${base}/photos/tjoint_patterns.png`, alt: 'Gallery of T-joint patterns' },
  { src: `${base}/photos/spoke_joint_side.png`, alt: 'Six-way spoke joint on a round post' },
  { src: `${base}/photos/pegged_bench_frame.png`, alt: 'Pegged mortise and tenon bench frame' },
  { src: `${base}/photos/panel_variations.png`, alt: 'Paneled and plain panel variations' },
];
---
<Layout title="Kumiki — timber-framing for code">
  <section class="hero">
    <div class="hero-copy">
      <h1>Kumiki</h1>
      <p class="tagline">
        A Python library for designing traditional timber frames in code, with a VS Code viewer
        called <strong>Kigumi</strong> for live 3D preview as you edit.
      </p>
      <div class="cta">
        <a class="btn btn-primary" href="https://github.com/minimapletinytools/kumiki" target="_blank" rel="noreferrer">
          View on GitHub
        </a>
        <a class="btn btn-secondary" href={`${base}/install`}>
          How to Install
        </a>
      </div>
    </div>
    <div class="hero-image">
      <img src={`${base}/photos/tinyhouse120_angle.png`} alt="Kumiki-rendered tiny house frame" />
    </div>
  </section>

  <section class="features">
    <article>
      <h3>Code your frames</h3>
      <p>Express timbers, joints, and assemblies as Python. Reuse patterns, parameterize sizes, and version-control your designs.</p>
    </article>
    <article>
      <h3>See them live</h3>
      <p>The Kigumi VS Code extension renders your frame in 3D and refreshes as you save — no separate CAD tool required.</p>
    </article>
    <article>
      <h3>Real joinery</h3>
      <p>Built-in support for traditional joints — mortise &amp; tenon, dovetails, half-laps, wedged variants, and more.</p>
    </article>
  </section>

  <section class="gallery">
    <h2>Gallery</h2>
    <div class="grid">
      {gallery.map((photo, i) => (
        <figure>
          <button class="thumb" type="button" data-index={i} aria-label={`Open larger view: ${photo.alt}`}>
            <img src={photo.src} alt={photo.alt} loading="lazy" />
          </button>
        </figure>
      ))}
    </div>
  </section>

  <div class="lightbox" id="lightbox" hidden>
    <button class="lightbox-close" type="button" aria-label="Close">&times;</button>
    <button class="lightbox-nav lightbox-prev" type="button" aria-label="Previous image">&#8249;</button>
    <img class="lightbox-image" id="lightbox-image" src="" alt="" />
    <button class="lightbox-nav lightbox-next" type="button" aria-label="Next image">&#8250;</button>
    <p class="lightbox-caption" id="lightbox-caption"></p>
  </div>
</Layout>

<script>
  const gallery = Array.from(document.querySelectorAll<HTMLButtonElement>('.thumb'));
  const lightbox = document.getElementById('lightbox') as HTMLDivElement | null;
  const lightboxImage = document.getElementById('lightbox-image') as HTMLImageElement | null;
  const lightboxCaption = document.getElementById('lightbox-caption');
  const closeBtn = lightbox?.querySelector<HTMLButtonElement>('.lightbox-close');
  const prevBtn = lightbox?.querySelector<HTMLButtonElement>('.lightbox-prev');
  const nextBtn = lightbox?.querySelector<HTMLButtonElement>('.lightbox-next');

  let currentIndex = 0;

  function show(index: number) {
    if (!lightbox || !lightboxImage || gallery.length === 0) return;
    currentIndex = (index + gallery.length) % gallery.length;
    const img = gallery[currentIndex].querySelector('img');
    if (!img) return;
    lightboxImage.src = img.src;
    lightboxImage.alt = img.alt;
    if (lightboxCaption) lightboxCaption.textContent = img.alt;
    lightbox.hidden = false;
    document.body.style.overflow = 'hidden';
  }

  function close() {
    if (!lightbox) return;
    lightbox.hidden = true;
    document.body.style.overflow = '';
  }

  gallery.forEach((btn, i) => {
    btn.addEventListener('click', () => show(i));
  });

  closeBtn?.addEventListener('click', close);
  prevBtn?.addEventListener('click', () => show(currentIndex - 1));
  nextBtn?.addEventListener('click', () => show(currentIndex + 1));

  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) close();
  });

  document.addEventListener('keydown', (e) => {
    if (!lightbox || lightbox.hidden) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') show(currentIndex - 1);
    if (e.key === 'ArrowRight') show(currentIndex + 1);
  });
</script>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 2.5rem;
    align-items: center;
    padding: 2.5rem 0 3.5rem;
  }
  .hero-copy h1 {
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    margin: 0 0 0.8rem;
    letter-spacing: -0.01em;
  }
  .tagline {
    font-size: 1.15rem;
    color: var(--ink-soft);
    margin: 0 0 1.6rem;
    max-width: 32ch;
  }
  .cta {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
  }
  .hero-image img {
    width: 100%;
    height: auto;
    border-radius: 0.9rem;
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
    background: var(--surface);
  }

  .features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
    margin: 1rem 0 3rem;
  }
  .features article {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.7rem;
    padding: 1.2rem 1.3rem;
  }
  .features h3 { margin: 0 0 0.4rem; font-size: 1.05rem; }
  .features p { margin: 0; color: var(--ink-soft); font-size: 0.95rem; }

  .gallery h2 {
    font-size: 1.4rem;
    margin: 0 0 1rem;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.9rem;
  }
  .grid figure {
    margin: 0;
    border-radius: 0.6rem;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--surface);
    aspect-ratio: 4 / 3;
  }
  .grid img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .thumb {
    display: block;
    width: 100%;
    height: 100%;
    padding: 0;
    margin: 0;
    border: none;
    background: none;
    cursor: zoom-in;
  }

  @media (max-width: 760px) {
    .hero { grid-template-columns: 1fr; padding: 1.5rem 0 2rem; }
    .features { grid-template-columns: 1fr; }
  }

  .lightbox[hidden] {
    display: none;
  }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-rows: 1fr auto;
    align-items: center;
    justify-items: center;
    gap: 0 1rem;
    padding: 3rem 1.5rem;
    background: rgba(20, 16, 10, 0.88);
  }

  .lightbox-image {
    grid-column: 2;
    grid-row: 1;
    max-width: 100%;
    max-height: calc(100vh - 8rem);
    object-fit: contain;
    border-radius: 0.5rem;
    box-shadow: var(--shadow);
  }

  .lightbox-caption {
    grid-column: 1 / -1;
    grid-row: 2;
    margin: 0.75rem 0 0;
    color: var(--surface);
    font-size: 0.9rem;
    text-align: center;
  }

  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1.2rem;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.08);
    color: var(--surface);
    font-size: 1.6rem;
    line-height: 1;
    cursor: pointer;
  }
  .lightbox-close:hover { background: rgba(255, 255, 255, 0.18); }

  .lightbox-nav {
    grid-row: 1;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.08);
    color: var(--surface);
    font-size: 1.8rem;
    line-height: 1;
    cursor: pointer;
    display: grid;
    place-items: center;
  }
  .lightbox-nav:hover { background: rgba(255, 255, 255, 0.18); }
  .lightbox-prev { grid-column: 1; }
  .lightbox-next { grid-column: 3; }

  @media (max-width: 640px) {
    .lightbox { padding: 3.5rem 0.75rem 1.5rem; }
    .lightbox-nav { width: 2.4rem; height: 2.4rem; font-size: 1.4rem; }
  }
</style>
