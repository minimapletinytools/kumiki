---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const gallery = [
  { src: `${base}/photos/oscarshed.png`, alt: "Oscar's Shed timber frame" },
  { src: `${base}/photos/sawhorsey.png`, alt: 'Sawhorse pattern' },
  { src: `${base}/photos/round_crosslap_joint.png`, alt: 'Round crosslap joint detail' },
  { src: `${base}/photos/wedged_half_dovetail.png`, alt: 'Wedged half dovetail joint' },
  { src: `${base}/photos/tinyhouse120_front.png`, alt: 'Tiny house, front view' },
  { src: `${base}/photos/extension-screenshot.png`, alt: 'Kigumi VS Code extension' },
];
---
<Layout title="Kumiki — timber-framing for code">
  <section class="hero">
    <div class="hero-copy">
      <h1>Kumiki</h1>
      <p class="tagline">
        A Python library for designing traditional timber frames in code, with a VS Code viewer
        called <strong>Kigumi</strong> for live 3D preview as you edit.
      </p>
      <div class="cta">
        <a class="btn btn-primary" href="https://github.com/minimapletinytools/kumiki" target="_blank" rel="noreferrer">
          View on GitHub
        </a>
        <a class="btn btn-secondary" href={`${base}/install`}>
          How to Install
        </a>
      </div>
    </div>
    <div class="hero-image">
      <img src={`${base}/photos/tinyhouse120_angle.png`} alt="Kumiki-rendered tiny house frame" />
    </div>
  </section>

  <section class="features">
    <article>
      <h3>Code your frames</h3>
      <p>Express timbers, joints, and assemblies as Python. Reuse patterns, parameterize sizes, and version-control your designs.</p>
    </article>
    <article>
      <h3>See them live</h3>
      <p>The Kigumi VS Code extension renders your frame in 3D and refreshes as you save — no separate CAD tool required.</p>
    </article>
    <article>
      <h3>Real joinery</h3>
      <p>Built-in support for traditional joints — mortise &amp; tenon, dovetails, half-laps, wedged variants, and more.</p>
    </article>
  </section>

  <section class="gallery">
    <h2>Gallery</h2>
    <div class="grid">
      {gallery.map((photo) => (
        <figure>
          <img src={photo.src} alt={photo.alt} loading="lazy" />
        </figure>
      ))}
    </div>
  </section>
</Layout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 2.5rem;
    align-items: center;
    padding: 2.5rem 0 3.5rem;
  }
  .hero-copy h1 {
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    margin: 0 0 0.8rem;
    letter-spacing: -0.01em;
  }
  .tagline {
    font-size: 1.15rem;
    color: var(--ink-soft);
    margin: 0 0 1.6rem;
    max-width: 32ch;
  }
  .cta {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
  }
  .hero-image img {
    width: 100%;
    height: auto;
    border-radius: 0.9rem;
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
    background: var(--surface);
  }

  .features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
    margin: 1rem 0 3rem;
  }
  .features article {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.7rem;
    padding: 1.2rem 1.3rem;
  }
  .features h3 { margin: 0 0 0.4rem; font-size: 1.05rem; }
  .features p { margin: 0; color: var(--ink-soft); font-size: 0.95rem; }

  .gallery h2 {
    font-size: 1.4rem;
    margin: 0 0 1rem;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.9rem;
  }
  .grid figure {
    margin: 0;
    border-radius: 0.6rem;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--surface);
    aspect-ratio: 4 / 3;
  }
  .grid img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 760px) {
    .hero { grid-template-columns: 1fr; padding: 1.5rem 0 2rem; }
    .features { grid-template-columns: 1fr; }
  }
</style>
