<style>
  .install {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 0 1rem;
  }
  .install h1 {
    font-size: 2.2rem;
    margin: 0 0 0.6rem;
  }
  .lead {
    color: var(--ink-soft);
    font-size: 1.05rem;
    margin: 0 0 1.4rem;
  }
  .todo-banner {
    background: var(--surface);
    border: 1px dashed var(--accent-soft);
    border-radius: 0.6rem;
    padding: 0.8rem 1rem;
    color: var(--ink-soft);
    margin-bottom: 2rem;
  }
  .install h2 {
    font-size: 1.2rem;
    margin: 1.8rem 0 0.4rem;
  }
  .install p { color: var(--ink-soft); margin: 0 0 0.6rem; }
  .install code {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.3rem;
    padding: 0.05rem 0.35rem;
    font-size: 0.92em;
  }
  .cta-row {
    display: flex;
    gap: 0.8rem;
    margin-top: 2.4rem;
    flex-wrap: wrap;
  }
</style>
